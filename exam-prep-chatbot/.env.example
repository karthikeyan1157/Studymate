# ── LLM Provider ─────────────────────────────────────────────────────────────
# Set to "groq" (default, free) or "openai"
LLM_PROVIDER=groq

# Groq API key — get one free at https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# OpenAI API key — only needed if LLM_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key-here

# ── Endee Vector DB ───────────────────────────────────────────────────────────
# URL of the Endee server (default: localhost:8080)
ENDEE_URL=http://localhost:8080/api/v1

# Auth token — only needed if you started Endee with NDD_AUTH_TOKEN set
# Leave blank for a local server with no auth
ENDEE_AUTH_TOKEN=

# ── Streamlit Frontend ────────────────────────────────────────────────────────
# URL of the FastAPI backend (used by frontend/app.py)
BACKEND_URL=http://localhost:8000
